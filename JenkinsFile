pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/arronoob/JenkinfFile_Project.git'
            }
        }

        stage('Build') {
            steps {
                dir('JenkinfFile_Project') {
                    sh 'mvn clean package'
                }
            }
        }
    }
}
